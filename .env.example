# Copy to .env and fill in your token from https://account.mapbox.com/
# Restart `npm run dev` after changing.

NUXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: richer transit map overlay + walk-vs-transit comparison in Transit mode (Maps JS + Directions on your key).
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: default is https://api.mapbox.com — point at a Cloudflare Worker proxy when ready.
# NUXT_PUBLIC_MAPBOX_API_BASE=https://api.mapbox.com
